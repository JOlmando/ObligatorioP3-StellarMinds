@model StellarMinds.AppWeb.Models.Dtos.Usuarios.GetUsuarioDto

<h1>Detalle de Usuario</h1>

<div class="card">

    <div class="card-body">

        <p><strong>Usuario:</strong> @Model.UserName</p>

        <p><strong>Nombre:</strong> @Model.Name</p>

        <p><strong>Email:</strong> @Model.Email</p>

        <p><strong>Calle:</strong> @Model.Calle</p>

        <p><strong>Número:</strong> @Model.NumeroPuerta</p>

        <p><strong>Apartamento:</strong> @Model.Apartamento</p>

        <p><strong>Rol:</strong> @Model.Rol</p>

    </div>

</div>

<br />

<a asp-action="Index"
       class="btn btn-secondary">
    Volver
</a>