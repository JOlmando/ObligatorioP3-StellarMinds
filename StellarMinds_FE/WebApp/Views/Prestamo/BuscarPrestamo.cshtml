@{
    ViewData["Title"] = "Buscar Préstamos";
}

<h2>Consultar Préstamos</h2>

<form asp-action="ListadoSocio" method="get">

    <div class="mb-3">
        <label>Usuario Id</label>
        <input type="number"
               name="usuarioId"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Mes</label>
        <input type="number"
               name="mes"
               min="1"
               max="12"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Año</label>
        <input type="number"
               name="anio"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Buscar
    </button>

</form>