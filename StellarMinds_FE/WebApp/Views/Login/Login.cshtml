@model StellarMinds.AppWeb.Models.Dtos.Usuarios.UsuarioLoginDto

@{
    ViewData["Title"] = "Ingresar";
}

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&display=swap" rel="stylesheet" />

<style>
    .login-wrap { min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 2rem 0; }
    .login-card { width: 100%; max-width: 400px; background: #fff; border: 1px solid #e5e5e5; border-radius: 16px; padding: 2.5rem; }
    .login-header { text-align: center; margin-bottom: 2rem; }
    .login-stars { font-size: 18px; letter-spacing: 6px; color: #EF9F27; margin-bottom: 12px; }
    .login-title { font-family: 'Cinzel', serif; font-size: 20px; font-weight: 600; letter-spacing: 2px; color: #0e0e1a; margin: 0 0 6px; }
    .login-sub { font-size: 13px; color: #888; margin: 0; }

    .login-label { font-size: 12px; letter-spacing: 0.5px; color: #555; text-transform: uppercase; margin-bottom: 6px; display: block; }
    .login-input { width: 100%; padding: 10px 14px; border: 1px solid #e5e5e5; border-radius: 8px; font-size: 14px; color: #1a1a2e; background: #fafafa; transition: border-color 0.2s, background 0.2s; outline: none; box-sizing: border-box; }
    .login-input:focus { border-color: #EF9F27; background: #fff; }
    .login-group { margin-bottom: 1.25rem; }

    .login-btn { width: 100%; padding: 11px; border-radius: 99px; border: none; background: #0e0e1a; color: #EF9F27; font-family: 'Cinzel', serif; font-size: 13px; letter-spacing: 2px; cursor: pointer; transition: background 0.2s; margin-top: 0.5rem; }
    .login-btn:hover { background: #1e1e35; }

    .login-error { background: #FCEBEB; border: 1px solid #F7C1C1; color: #791F1F; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 1.25rem; text-align: center; }
    .login-validation { font-size: 12px; color: #A32D2D; margin-top: 4px; display: block; }
    .login-footer { text-align: center; margin-top: 1.5rem; }
    .login-footer a { font-size: 12px; color: #888; text-decoration: none; letter-spacing: 0.5px; }
    .login-footer a:hover { color: #EF9F27; }
    .login-divider { height: 1px; background: #e5e5e5; margin: 1.5rem 0; }
</style>

<div class="login-wrap">
    <div class="login-card">
        <div class="login-header">
            <div class="login-stars">✦ ★ ✦</div>
            <h1 class="login-title">Stellar Minds</h1>
            <p class="login-sub">Ingresá al observatorio</p>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="login-error">@ViewBag.ErrorMessage</div>
        }

        @* <div asp-validation-summary="ModelOnly" class="login-error" ></div> *@

        <form asp-action="Login">
            <div class="login-group">
                <label asp-for="username" class="login-label"></label>
                <input asp-for="username" class="login-input" placeholder="Tu nombre de usuario" autocomplete="username" />
                <span asp-validation-for="username" class="login-validation"></span>
            </div>
            <div class="login-group">
                <label asp-for="password" class="login-label"></label>
                <input asp-for="password" type="password" class="login-input" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="password" class="login-validation"></span>
            </div>
            <button type="submit" class="login-btn">Ingresar ✦</button>
        </form>

        <div class="login-divider"></div>
        <div class="login-footer">
            <a asp-controller="Home" asp-action="Index">← Volver al inicio</a>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
